# URL de conexión a MongoDB Atlas
MONGODB_URI="mongodb+srv://<usuario>:<password>@<cluster>.mongodb.net/<base-de-datos>?retryWrites=true&w=majority"

# Clave secreta para la sesión/encriptación de Payload CMS
PAYLOAD_SECRET="tu-clave-secreta-de-payload"

# Credenciales de Cloudinary para almacenamiento multimedia
CLOUDINARY_CLOUD_NAME="tu-cloud-name"
CLOUDINARY_API_KEY="tu-api-key"
CLOUDINARY_API_SECRET="tu-api-secret"

# Configuración del Panel de Administración (ruta camuflada)
PANEL_ROUTE="/admin"

# Número de WhatsApp para recibir los pedidos del carrito (formato internacional sin el signo '+')
# Ejemplo: 50761416952
WHATSAPP_NUMBER="50761416952"

# URL de la API de Saleor (puedes dejar el valor de ejemplo, pero el sistema ahora usa la API local de Payload)
NEXT_PUBLIC_SALEOR_API_URL="https://your-instance.saleor.cloud/graphql/"

# URL del Storefront
NEXT_PUBLIC_STOREFRONT_URL="http://localhost:3000"

# Canal por defecto para el ruteo del catálogo
NEXT_PUBLIC_DEFAULT_CHANNEL="default-channel"
